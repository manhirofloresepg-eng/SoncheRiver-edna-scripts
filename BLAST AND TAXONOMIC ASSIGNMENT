# ------------------------------------------------------------------------------
# 1. INSTALL AND LOAD REQUIRED PACKAGES
# ------------------------------------------------------------------------------

# install.packages(c("tidyverse", "Biostrings", "openxlsx"))

library(tidyverse)
library(Biostrings)
library(openxlsx)

# ------------------------------------------------------------------------------
# 2. SET WORKING DIRECTORY
# ------------------------------------------------------------------------------

setwd("~/proyectos/sonche_edna/")

# Create directory structure
dir.create("data/raw", showWarnings = FALSE)
dir.create("data/processed", showWarnings = FALSE)
dir.create("data/reference", showWarnings = FALSE)
dir.create("output/tables", showWarnings = FALSE)

# ------------------------------------------------------------------------------
# 3. LOAD CONSENSUS SEQUENCES (FROM DECONA/MEDAKA)
# ------------------------------------------------------------------------------

# Read FASTA file with consensus sequences generated by DECONA
# These are sequences filtered by quality (Q10) and length (160-240 bp)

# If you already have the file:
# sequences <- readDNAStringSet("data/processed/consensus_decana.fasta")

# EXAMPLE (replace with your actual data)
consensus_sequences <- DNAStringSet(c(
  "ACGTAGCATGCTAGCTAGCTAGCTAGCATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGTAGCTACGATCG",
  "ACGTAGCATGCTAGCTAGCTAGCTAGCATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGTAGCTACGATCG",
  "ACGTAGCATGCTAGCTAGCTAGCTAGCATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGTAGCTACGATCG",
  "ACGTAGCATGCTAGCTAGCTAGCTAGCATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGTAGCTACGATCG",
  "ACGTAGCATGCTAGCTAGCTAGCTAGCATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGTAGCTACGATCG"
))
names(consensus_sequences) <- paste0("consensus_", 1:5)

# Save sequences for BLAST
writeXStringSet(consensus_sequences, "data/processed/consensus_for_blast.fasta")
cat("✓ Consensus sequence file saved\n")

# ------------------------------------------------------------------------------
# 4. CREATE LOCAL BLAST REFERENCE DATABASE
# ------------------------------------------------------------------------------

# NOTE: This step requires BLAST+ installed on your system
# Download BLAST+: https://ftp.ncbi.nlm.nih.gov/blast/executables/blast+/LATEST/

# Load reference sequences (downloaded from GenBank)
# If you already have the FASTA file:
# ref_seqs <- readDNAStringSet("data/reference/ref_12s_actinopterygii.fasta")

# EXAMPLE (replace with your actual reference sequences)
ref_sequences <- DNAStringSet(c(
  "ACGTAGCATGCTAGCTAGCTAGCTAGCATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGTAGCTACGATCG",
  "ACGTAGCATGCTAGCTAGCTAGCTAGCATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGTAGCTACGATCG",
  "ACGTAGCATGCTAGCTAGCTAGCTAGCATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGTAGCTACGATCG",
  "ACGTAGCATGCTAGCTAGCTAGCTAGCATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGATCGTAGCTACGATCG"
))
names(ref_sequences) <- c("Chaetostoma_milesi_12S", "Astroblepus_sp_12S", 
                          "Oncorhynchus_mykiss_12S", "Brycon_sp_12S")

writeXStringSet(ref_sequences, "data/reference/ref_12s_actinopterygii.fasta")
cat("✓ Reference FASTA file saved\n")

# Create BLAST database (system command)
# On Linux/Mac: "makeblastdb"
# On Windows: "C:/Program Files/NCBI/blast-bin/makeblastdb.exe"

blast_db_cmd <- paste(
  "makeblastdb",
  "-in data/reference/ref_12s_actinopterygii.fasta",
  "-dbtype nucl",
  "-out data/reference/ref_12s_actinopterygii"
)
system(blast_db_cmd, wait = TRUE)
cat("✓ BLAST database created\n")

# ------------------------------------------------------------------------------
# 5. RUN BLASTN AGAINST LOCAL DATABASE
# ------------------------------------------------------------------------------

# Input and output files
consensus_file <- "data/processed/consensus_for_blast.fasta"
blast_output_file <- "data/processed/blast_results.txt"

# BLAST command (optimized for Nanopore reads)
blast_cmd <- paste(
  "blastn",
  "-db data/reference/ref_12s_actinopterygii",
  "-query", consensus_file,
  "-out", blast_output_file,
  "-outfmt '6 qseqid sseqid pident length mismatch gapopen qstart qend sstart send evalue bitscore'",
  "-evalue 1e-5",
  "-perc_identity 85",
  "-num_threads 4"
)
system(blast_cmd, wait = TRUE)
cat("✓ BLAST completed\n")

# ------------------------------------------------------------------------------
# 6. LOAD AND PROCESS BLAST RESULTS
# ------------------------------------------------------------------------------

# Read BLAST results (tabular format)
blast_results <- read.table(
  blast_output_file,
  header = FALSE,
  sep = "\t",
  col.names = c("qseqid", "sseqid", "pident", "length", "mismatch", 
                "gapopen", "qstart", "qend", "sstart", "send", "evalue", "bitscore"),
  fill = TRUE
)

cat("\n========== BLAST RESULTS ==========\n")
cat("Total alignments found:", nrow(blast_results), "\n")

if (nrow(blast_results) > 0) {
  
  # Process BLAST results
  blast_results <- blast_results %>%
    mutate(
      Target_Taxon = sseqid,
      # Extract genus from reference sequence ID
      Genus = str_extract(Target_Taxon, "^[A-Za-z]+"),
      Species = str_extract(Target_Taxon, "[A-Za-z]+_[A-Za-z]+")
    ) %>%
    # Keep only the best hit per query (highest bitscore)
    group_by(qseqid) %>%
    slice_max(order_by = bitscore, n = 1) %>%
    ungroup()
  
  # Save raw BLAST results
  write.xlsx(blast_results, "output/tables/blast_results_raw.xlsx")
  cat("✓ Raw BLAST results saved\n")
  
} else {
  cat("No BLAST alignments found\n")
}

# ------------------------------------------------------------------------------
# 7. TAXONOMIC ASSIGNMENT BASED ON IDENTITY CUTOFFS
# ------------------------------------------------------------------------------

taxonomy_assigned <- blast_results %>%
  mutate(
    Assignment_Level = case_when(
      pident >= 97 ~ "Species",
      pident >= 90 & pident < 97 ~ "Genus",
      pident >= 85 & pident < 90 ~ "Family",
      TRUE ~ "Unassigned"
    ),
    # If Species, use full name; if Genus, use only genus
    Assigned_Name = case_when(
      Assignment_Level == "Species" ~ str_replace(Target_Taxon, "_12S$", ""),
      Assignment_Level == "Genus" ~ Genus,
      Assignment_Level == "Family" ~ str_extract(Target_Taxon, "^[A-Za-z]+"),
      TRUE ~ "Unclassified"
    )
  )

cat("\n========== TAXONOMIC ASSIGNMENT SUMMARY ==========\n")
print(table(taxonomy_assigned$Assignment_Level))
cat("\n")

# Export complete taxonomic assignment
write.xlsx(taxonomy_assigned, "output/tables/taxonomic_assignment_complete.xlsx")
cat("✓ Taxonomic assignment saved\n")

# ------------------------------------------------------------------------------
# 8. EXPORT SUMMARY TABLE FOR ANALYSIS SCRIPT
# ------------------------------------------------------------------------------

# Create simplified table for downstream analysis
taxonomy_summary <- taxonomy_assigned %>%
  select(qseqid, Assigned_Name, Assignment_Level, pident, bitscore, evalue)

write.xlsx(taxonomy_summary, "output/tables/taxonomy_for_analysis.xlsx")
cat("✓ Taxonomy summary exported for analysis\n")

cat("\n========== SCRIPT 1 COMPLETED ==========\n")
cat("Output files:\n")
cat("  - data/processed/consensus_for_blast.fasta\n")
cat("  - data/processed/blast_results.txt\n")
cat("  - output/tables/blast_results_raw.xlsx\n")
cat("  - output/tables/taxonomic_assignment_complete.xlsx\n")
cat("  - output/tables/taxonomy_for_analysis.xlsx\n")
cat("=======================================\n")
